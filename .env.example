# --- Database -------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://certguard:certguard@db:5432/certguard

# --- Storage paths ---------------------------------------------------------
STORAGE_DIR=./storage
CERTIFICATES_DIR=./storage/certificates
SUSPICIOUS_DIR=./storage/suspicious
MODELS_DIR=./models
LOGS_DIR=./logs

# --- Limits ----------------------------------------------------------------
MAX_PDF_SIZE_MB=10
MIN_FREE_SPACE_MB=15
MAX_TEXT_BYTES=3145728

# --- TF-IDF / matching -----------------------------------------------------
TFIDF_MAX_FEATURES=5000
SIMILARITY_THRESHOLD=0.7
NN_NEIGHBORS=1

# --- Email (SMTP) ----------------------------------------------------------
# Leave SMTP_HOST empty to run in simulated-delivery mode (logs instead of sending).
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@certguard.local
EMAIL_MAX_RETRIES=3

# --- Archival --------------------------------------------------------------
ARCHIVE_AFTER_DAYS=5
